<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Red Light Tattoo Studio | San Marcos, TX — Open Late</title>
<meta name="description" content="Red Light Tattoo Studio in San Marcos, TX. Walk-ins welcome. Appointments recommended. Fine line, black & gray, color, and bold blackwork by resident artists. 109 E. Hopkins St., Suite 206.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Bebas+Neue&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --black:       #0a0808;
    --charcoal:    #141010;
    --graphite:    #1e1818;
    --smoke:       #2a2222;
    --crimson:     #8b1a1a;
    --oxblood:     #5c0f0f;
    --red-glow:    #c0392b;
    --ember:       #e8442a;
    --bone:        #e8e0d5;
    --warm-white:  #f5f0e8;
    --muted:       #9a8f8a;
    --glass:       rgba(30, 24, 24, 0.72);
    --glass-light: rgba(44, 36, 36, 0.55);
    --border:      rgba(139, 26, 26, 0.25);
    --border-soft: rgba(232, 224, 213, 0.08);

    --font-display: 'Bebas Neue', sans-serif;
    --font-serif:   'Cormorant Garamond', Georgia, serif;
    --font-mono:    'DM Mono', monospace;
  }

  /* ===== RESET & BASE ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--bone);
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.7;
    overflow-x: hidden;
    cursor: default;
  }

  ::selection { background: var(--crimson); color: var(--bone); }

  /* ===== NOISE TEXTURE OVERLAY ===== */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--black); }
  ::-webkit-scrollbar-thumb { background: var(--crimson); }

  /* ===== UTILITY ===== */
  .container { max-width: 1140px; margin: 0 auto; padding: 0 32px; }
  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--red-glow);
    opacity: 0.85;
  }
  .divider {
    width: 48px;
    height: 1px;
    background: linear-gradient(to right, var(--crimson), transparent);
    margin: 16px 0 28px;
  }
  .divider-center {
    margin: 16px auto 28px;
  }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes glowPulse {
    0%, 100% { text-shadow: 0 0 18px rgba(192,57,43,0.3); }
    50%       { text-shadow: 0 0 36px rgba(192,57,43,0.55), 0 0 72px rgba(192,57,43,0.2); }
  }
  @keyframes lineExtend {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
  @keyframes subtleFloat {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.75s cubic-bezier(0.22,1,0.36,1), transform 0.75s cubic-bezier(0.22,1,0.36,1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== NAV ===== */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    padding: 20px 0;
    background: linear-gradient(to bottom, rgba(10,8,8,0.98) 0%, transparent 100%);
    transition: background 0.4s;
  }
  nav.scrolled {
    background: rgba(10,8,8,0.97);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.12em;
    color: var(--bone);
    text-decoration: none;
    transition: color 0.3s;
  }
  .nav-logo span { color: var(--red-glow); }
  .nav-logo:hover { color: var(--warm-white); }
  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  .nav-links a {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0; right: 0;
    height: 1px;
    background: var(--red-glow);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1);
  }
  .nav-links a:hover { color: var(--bone); }
  .nav-links a:hover::after { transform: scaleX(1); }
  .nav-cta {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bone);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 8px 20px;
    transition: all 0.3s;
    background: transparent;
  }
  .nav-cta:hover {
    background: var(--crimson);
    border-color: var(--crimson);
    color: var(--warm-white);
  }

  /* ===== HERO ===== */
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
    padding-bottom: 100px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 70%, rgba(92,15,15,0.35) 0%, transparent 70%),
      radial-gradient(ellipse 30% 40% at 20% 80%, rgba(139,26,26,0.18) 0%, transparent 60%),
      linear-gradient(to bottom, rgba(10,8,8,0.3) 0%, rgba(10,8,8,0.85) 75%, var(--black) 100%),
      var(--graphite);
  }
  /* Subtle geometric grid lines */
  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(139,26,26,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139,26,26,0.06) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.4) 40%, rgba(0,0,0,0.4) 70%, transparent 100%);
  }
  /* Red neon vertical accent */
  .hero-bg::after {
    content: '';
    position: absolute;
    right: 15%;
    top: 10%;
    width: 2px;
    height: 55%;
    background: linear-gradient(to bottom, transparent, var(--crimson), var(--oxblood), transparent);
    box-shadow: 0 0 40px rgba(192,57,43,0.4), 0 0 80px rgba(192,57,43,0.15);
    opacity: 0.7;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 780px;
  }
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--red-glow);
    margin-bottom: 20px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(64px, 10vw, 128px);
    line-height: 0.92;
    letter-spacing: 0.04em;
    color: var(--bone);
    margin-bottom: 10px;
    opacity: 0;
    animation: fadeUp 0.9s 0.35s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .hero-title .red { color: var(--red-glow); animation: glowPulse 4s 1.5s ease-in-out infinite; }
  .hero-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(18px, 2.2vw, 26px);
    font-weight: 300;
    color: var(--muted);
    margin-top: 16px;
    margin-bottom: 40px;
    max-width: 480px;
    opacity: 0;
    animation: fadeUp 0.9s 0.5s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .hero-actions {
    display: flex;
    gap: 20px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.9s 0.65s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .btn-primary {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--warm-white);
    background: var(--crimson);
    border: 1px solid var(--crimson);
    padding: 14px 32px;
    text-decoration: none;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--red-glow);
    transform: translateX(-100%);
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }
  .btn-primary:hover::before { transform: translateX(0); }
  .btn-primary span { position: relative; z-index: 1; }
  .btn-ghost {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid rgba(154,143,138,0.3);
    padding-bottom: 2px;
    transition: color 0.3s, border-color 0.3s;
  }
  .btn-ghost:hover { color: var(--bone); border-color: var(--bone); }
  .hero-meta {
    position: absolute;
    bottom: 40px;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    opacity: 0;
    animation: fadeUp 0.9s 0.8s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .hero-meta span {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0.7;
  }
  .hero-meta .open {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--red-glow);
    opacity: 1;
  }

  /* ===== SECTION SPACING ===== */
  section { padding: 100px 0; }
  section + section { padding-top: 0; }

  /* ===== STUDIO INTRO ===== */
  #intro {
    padding: 100px 0;
    border-top: 1px solid var(--border-soft);
  }
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .intro-text h2 {
    font-family: var(--font-display);
    font-size: clamp(42px, 5vw, 68px);
    letter-spacing: 0.06em;
    line-height: 0.95;
    color: var(--bone);
    margin-bottom: 28px;
  }
  .intro-text p {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.9;
    margin-bottom: 16px;
  }
  .intro-text p strong { color: var(--bone); font-weight: 400; }
  .intro-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }
  .stat-block {
    background: var(--graphite);
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .stat-block::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, var(--crimson), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }
  .stat-block:hover { background: var(--smoke); }
  .stat-block:hover::before { transform: scaleX(1); }
  .stat-num {
    font-family: var(--font-display);
    font-size: 48px;
    letter-spacing: 0.06em;
    color: var(--red-glow);
    line-height: 1;
    margin-bottom: 8px;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ===== ARTISTS ===== */
  #artists {
    padding: 100px 0;
    background: var(--charcoal);
    border-top: 1px solid var(--border-soft);
    border-bottom: 1px solid var(--border-soft);
  }
  .section-header {
    margin-bottom: 64px;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 72px);
    letter-spacing: 0.07em;
    line-height: 0.95;
    color: var(--bone);
  }
  .artists-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border);
  }
  .artist-card {
    background: var(--graphite);
    padding: 48px 36px;
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: background 0.4s;
  }
  .artist-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(to right, transparent, var(--crimson), transparent);
    transform: scaleX(0);
    transition: transform 0.5s cubic-bezier(0.22,1,0.36,1);
  }
  .artist-card:hover { background: var(--smoke); }
  .artist-card:hover::after { transform: scaleX(1); }
  .artist-number {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.22em;
    color: var(--oxblood);
    margin-bottom: 28px;
    display: block;
  }
  .artist-name {
    font-family: var(--font-display);
    font-size: 40px;
    letter-spacing: 0.08em;
    color: var(--bone);
    line-height: 0.95;
    margin-bottom: 6px;
  }
  .artist-handle {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.14em;
    color: var(--red-glow);
    margin-bottom: 24px;
    opacity: 0.8;
  }
  .artist-styles {
    list-style: none;
    margin-bottom: 28px;
  }
  .artist-styles li {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 5px 0;
    border-bottom: 1px solid rgba(154,143,138,0.12);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .artist-styles li::before {
    content: '—';
    color: var(--crimson);
    font-size: 10px;
  }
  .artist-bio {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 28px;
  }
  .artist-draft-note {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--oxblood);
    border: 1px solid var(--oxblood);
    padding: 4px 10px;
    display: inline-block;
    margin-top: -12px;
    margin-bottom: 16px;
    opacity: 0.7;
  }
  .artist-link {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--bone);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 0.3s;
  }
  .artist-link::after {
    content: '→';
    transition: transform 0.3s;
  }
  .artist-link:hover { color: var(--red-glow); }
  .artist-link:hover::after { transform: translateX(4px); }

  /* ===== STYLES / SERVICES ===== */
  #styles {
    padding: 100px 0;
  }
  .styles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border-soft);
    margin-top: 56px;
  }
  .style-item {
    background: var(--black);
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .style-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--crimson);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }
  .style-item:hover { background: var(--charcoal); }
  .style-item:hover::before { transform: scaleY(1); }
  .style-icon {
    width: 32px;
    height: 1px;
    background: linear-gradient(to right, var(--crimson), transparent);
    margin-bottom: 24px;
  }
  .style-name {
    font-family: var(--font-display);
    font-size: 28px;
    letter-spacing: 0.1em;
    color: var(--bone);
    margin-bottom: 12px;
  }
  .style-desc {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.8;
  }

  /* ===== GALLERY STRIP ===== */
  #gallery {
    padding: 80px 0;
    background: var(--charcoal);
    border-top: 1px solid var(--border-soft);
    border-bottom: 1px solid var(--border-soft);
    overflow: hidden;
  }
  .gallery-label-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
  }
  .gallery-placeholder-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2px;
  }
  .gallery-placeholder {
    aspect-ratio: 3/4;
    background: var(--graphite);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }
  .gallery-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(92,15,15,0.6), transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .gallery-placeholder:hover { transform: scale(1.02); }
  .gallery-placeholder:hover::before { opacity: 1; }
  .gallery-placeholder-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 8px;
  }
  .gallery-placeholder-inner span {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--smoke);
  }
  /* Varied heights for editorial feel */
  .gallery-placeholder:nth-child(2),
  .gallery-placeholder:nth-child(5) { aspect-ratio: 3/5; }
  .gallery-note {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--oxblood);
    text-transform: uppercase;
    margin-top: 20px;
    opacity: 0.7;
    text-align: right;
  }

  /* ===== WALK-INS / BOOKING ===== */
  #booking {
    padding: 100px 0;
  }
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--border);
    margin-top: 56px;
  }
  .booking-panel {
    background: var(--graphite);
    padding: 60px 48px;
    position: relative;
    overflow: hidden;
  }
  .booking-panel.featured {
    background: var(--smoke);
  }
  .booking-panel h3 {
    font-family: var(--font-display);
    font-size: 38px;
    letter-spacing: 0.08em;
    color: var(--bone);
    margin-bottom: 12px;
    margin-top: 16px;
  }
  .booking-panel p {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.85;
    margin-bottom: 32px;
  }
  .booking-detail {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 36px;
  }
  .booking-detail-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .booking-detail-item .bd-label {
    color: var(--red-glow);
    min-width: 80px;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding-top: 1px;
  }
  .booking-accent {
    position: absolute;
    top: 0; right: 0;
    width: 120px; height: 120px;
    background: radial-gradient(circle at top right, rgba(139,26,26,0.25), transparent 70%);
  }

  /* ===== FAQ ===== */
  #faq {
    padding: 100px 0;
    background: var(--charcoal);
    border-top: 1px solid var(--border-soft);
  }
  .faq-grid {
